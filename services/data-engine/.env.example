# NOXUND data-engine (Python) — environment template
# Copy to .env locally. NEVER commit real values.

# --- YouTube Data API v3 (server-side only) ---
YOUTUBE_API_KEY=

# --- Database (Supabase Postgres connection for writing raw/computed) ---
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM for Entity Resolution Agent ONLY (assist; output validated deterministically) ---
ANTHROPIC_API_KEY=

# --- Run config ---
NOXUND_KEYWORD=chicago drill type beat
NOXUND_WINDOW_DAYS=30
NOXUND_TARGET_VIDEO_COUNT=500

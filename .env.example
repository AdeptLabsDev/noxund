# NOXUND — environment template.
# Copy to .env (gitignored) and fill locally. NEVER commit real values.
# Secrets are server-side only (see docs/agents/global-agent-rules.md #10).

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_NOXUND_ENV=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API
YOUTUBE_API_KEY=

# Email provider
EMAIL_PROVIDER=
RESEND_API_KEY=
POSTMARK_API_KEY=

# Internal jobs / cron
INTERNAL_JOB_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

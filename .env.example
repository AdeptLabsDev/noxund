# NOXUND — environment template.
# Copy to .env (gitignored) and fill locally. NEVER commit real values.
# Secrets are server-side only (see docs/agents/global-agent-rules.md #10).

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_NOXUND_ENV=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API
YOUTUBE_API_KEY=

# Email provider
EMAIL_PROVIDER=
RESEND_API_KEY=
POSTMARK_API_KEY=

# Internal jobs / cron
INTERNAL_JOB_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Supabase CLI / CI migration apply — OPERATOR & PIPELINE ONLY (not app runtime).
# These do NOT belong in a local app `.env`. Their real values live exclusively
# in the CI vault / GitHub Environment `production-db`, populated out-of-band by
# the Product Lead. Full spec: docs/infra/INFRA-0001-phase1-credentialed-env.md.
#   secrets:   SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD (+ SUPABASE_SERVICE_ROLE_KEY above)
#   non-secret vars: SUPABASE_PROJECT_REF, SUPABASE_DB_HOST, SUPABASE_DB_PORT, SUPABASE_DB_USER
# ---------------------------------------------------------------------------
